###############################################################################
# Project
###############################################################################

TARGET = rt-linux-ai

###############################################################################
# Compiler
###############################################################################

CC = gcc

CFLAGS = -Wall -Wextra \
          -Iinclude \
          -Idrivers \
          -Itasks \
          -Icore

LDFLAGS = -pthread

###############################################################################
# Sources
###############################################################################

SRC = \
	app/main.c \
	drivers/camera.c \
	tasks/task_capture.c \
	core/time_utils.c

OBJ = $(SRC:.c=.o)

###############################################################################
# Build
###############################################################################

all: $(TARGET)

$(TARGET): $(OBJ)
	$(CC) $(OBJ) -o $(TARGET) $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

###############################################################################
# Clean
###############################################################################

clean:
	rm -f $(OBJ) $(TARGET)

.PHONY: all clean