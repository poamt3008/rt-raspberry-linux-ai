###############################################################################
# Project
###############################################################################

TARGET = rt-linux-ai

###############################################################################
# Compiler
###############################################################################

CC = gcc

INCLUDES = \
	-Iinclude \
	-Idrivers

CFLAGS = -Wall -Wextra $(INCLUDES)

LDFLAGS =

###############################################################################
# Sources
###############################################################################

SRC = \
	app/main.c \
	drivers/camera.c

OBJ = $(SRC:.c=.o)

###############################################################################
# Build
###############################################################################

all: $(TARGET)

$(TARGET): $(OBJ)
	$(CC) $(OBJ) -o $(TARGET) $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

###############################################################################
# Clean
###############################################################################

clean:
	rm -f $(OBJ) $(TARGET)

.PHONY: all clean